# Copy to .env to override compose defaults locally.
APP_ENV=dev
DEBUG=true

PG_HOST=localhost
PG_PORT=5432
PG_USER=aiforen
PG_PASSWORD=aiforen_dev
PG_DB=aiforen

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-secret-change-me
# Access token lifetime (minutes). 10080 = 7 days.
JWT_ACCESS_TTL_MINUTES=10080
# Refresh token lifetime (days). Used for silent re-login.
JWT_REFRESH_TTL_DAYS=365
FRONTEND_BASE_URL=http://localhost:3000
# Production (Railway): https://primevocab.com — also merged into CORS automatically

# Leave blank to fall through to insecure dev decoding.
# Web OAuth client — must match NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend.
GOOGLE_CLIENT_ID=
# Secret from the same OAuth client as GOOGLE_CLIENT_ID (not a different client).
GOOGLE_CLIENT_SECRET=

# Daily mission: one word = one task (LLM picks template from catalog)
VOCAB_WORD_TASK_MISSION=0

LLM_PROVIDER=mock
PAYMENT_PROVIDER=mock
STORAGE_PROVIDER=local
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional override for vocab Step 3 AI (defaults to OPENAI_MODEL)
OPENAI_VOCAB_EVAL_MODEL=

# Fast vocab VI gloss (transipy — free Google Translate, parallel chunks)
TRANSIPY_CHUNK_SIZE=16

# Extra origins; FRONTEND_BASE_URL is always merged in at startup
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Production example:
# APP_ENV=production
# DEBUG=false
# FRONTEND_BASE_URL=https://primevocab.com
# CORS_ORIGINS=["https://primevocab.com","https://www.primevocab.com"]
# GOOGLE_REDIRECT_URI=https://primevocab.com/auth/callback
